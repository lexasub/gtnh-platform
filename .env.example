# GTNH Platform — Service Ports
# These are hardcoded in service source files. This file documents them.
# Services do NOT read from env yet — values are for reference only.

# MessageRouter (Go) — internal pub/sub broker
ROUTER_HOST=127.0.0.1
ROUTER_PORT=4000

# ChunkStore (C++) — LMDB block storage, RPC
CHUNK_STORE_HOST=127.0.0.1
CHUNK_STORE_RPC_PORT=5001

# EntityStateStore (C++) — entity state persistence, TCP RPC
ENTITY_STATE_STORE_HOST=127.0.0.1
ENTITY_STATE_STORE_RPC_PORT=5200

# MetaDB (Go) — player saves, inventories
METADB_HOST=127.0.0.1
METADB_JSON_PORT=5005
METADB_RPC_PORT=5006

# Gateway (C++) — TCP gateway, client-facing
GATEWAY_CTRL_PORT=7777
GATEWAY_BULK_PORT=7778
