// protocol/gateway.fbs
// Gateway ‚Üî Client binary protocol.
// Wire format: [4 bytes: big-endian payload size] [1 byte: message type] [FlatBuffer]
//   Types: 0=PlayerAction (client‚Üígateway), 1=ChunkData (gateway‚Üíclient),
//         2=EntitySnapshot (gateway‚Üíclient), 3=BlockAck (gateway‚Üíclient),
//         4=SetBlockAction (client‚Üígateway), 5=InventoryUpdate (gateway‚Üíclient),
//         6=InventoryAction (client‚Üígateway),
//         7=CraftRequest (client‚Üígateway), 8=CraftResponse (gateway‚Üíclient),
//         9=GridUpdate (gateway‚Üíclient), 10=BlockEntityUpdate (gateway‚Üíclient),
//        11=CompressedChunkData (gateway‚Üíclient), 12=ToolAction (client‚Üígateway),
//        13=ToolActionResp (gateway‚Üíclient), 14=MachineAction (client‚Üígateway),
//        15=MachineActionResp (gateway‚Üíclient),
//        16=SetMachineSlotResp (gateway‚Üíclient),
//        17=ChestOpenReq (client‚Üígateway),
//        18=ChestOpenResp (gateway‚Üíclient)

include "core.fbs";

namespace Protocol;

union GatewayPayload {
  PlayerAction,       // 0 ‚Äî client‚Üígateway
  ChunkData,          // 1 ‚Äî gateway‚Üíclient (full chunk, on first load or resync)
  EntitySnapshot,     // 2 ‚Äî gateway‚Üíclient
  BlockAck,           // 3 ‚Äî gateway‚Üíclient (commit confirmation / rejection)
  SetBlockAction,     // 4 ‚Äî client‚Üígateway (CAS block placement)
  InventoryUpdate,    // 5 ‚Äî gateway‚Üíclient (inventory snapshot / update)
  InventoryAction,    // 6 ‚Äî client‚Üígateway (inventory operation)
  CraftRequest,       // 7 ‚Äî client‚Üígateway (craft from workbench)
  CraftResponse,      // 8 ‚Äî gateway‚Üíclient (craft result)
  GridUpdate,         // 9 ‚Äî gateway‚Üíclient (workbench grid state)
  BlockEntityUpdate,  // 10 ‚Äî gateway‚Üíclient (machine/multiblock state)
  CompressedChunkData,// 11 ‚Äî gateway‚Üíclient (lazy decoded chunk)
  ToolAction,         // 12 ‚Äî client‚Üígateway (tool use: drill, wrench)
  ToolActionResp,     // 13 ‚Äî gateway‚Üíclient (tool action result)
  MachineAction,      // 14 ‚Äî client‚Üígateway (machine config changes)
  MachineActionResp,  // 15 ‚Äî gateway‚Üíclient (machine config result)
  SetMachineSlotResp, // 16 ‚Äî gateway‚Üíclient (machine slot ACK)
  ChestOpenReq,       // 17 ‚Äî client‚Üígateway (chest open request)
  ChestOpenResp,      // 18 ‚Äî gateway‚Üíclient (chest open response)
}

table GatewayMessage {
  payload:GatewayPayload (required);
}

root_type GatewayMessage;
